# OpenAI
OPENAI_API_KEY=

# Upstash Vector (similarity cache) — index must be dimension 1536, cosine
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Upstash Redis (metric counters)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Neon Postgres (durable per-user/per-repo interaction history)
# Vercel Marketplace → Neon, or neon.tech. Use the pooled connection string.
DATABASE_URL=

# GitHub OAuth (Auth.js v5). Create an OAuth App:
#   Homepage:            http://localhost:3000
#   Authorization callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
